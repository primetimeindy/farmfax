# ParcelProof optional live integrations

# Stripe Payment Link / hosted Checkout URL. If unset, app falls back to local test modal.
VITE_STRIPE_CHECKOUT_URL=

# Optional parcel provider configuration. Do NOT expose secret server API keys in Vite client builds.
# Prefer a backend proxy URL here, e.g. /api/parcel? or a public provider handoff URL.
VITE_PARCEL_PROVIDER_URL=

# Regrid key detection only; frontend will not call Regrid directly with a secret key.
VITE_REGRID_API_KEY=
